4.0 RUSSIAN HELP TEXT                                      2
    4.1 C:\LTGOLD\LTGOLD -HR                               2

5.0 AUTOMATIC RUSSIAN                                      2
    5.1 C:\LTGOLD\LTGOLD -AR                               2

6.0 PEEKING AT THE DICTIONARY                              2
    6.1 C:\LTGOLD\LTGOLD -@                                3

